{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task risk assessment",
  "type": "object",
  "required": ["results"],
  "additionalProperties": false,
  "properties": {
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "risk", "reason", "requiresApproval"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "requiresApproval": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
