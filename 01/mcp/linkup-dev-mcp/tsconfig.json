{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts", "test/unit/**/*.ts", "test/integration/**/*.ts", "test/protocol/**/*.ts", "test/contract/**/*.ts", "test/security/**/*.ts", "test/runtime/**/*.ts"],
  "exclude": ["node_modules", "dist", "test/fixtures"]
}
