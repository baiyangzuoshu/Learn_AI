{
  "name": "linkup-check",
  "version": "0.1.0",
  "description": "Deterministic static checker for LinkUpClient project",
  "type": "module",
  "bin": {
    "linkup-check": "./bin/linkup-check.mjs"
  },
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "check": "node bin/linkup-check.mjs --project ../../LinkUpClient"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["linkup", "cocos", "prefab", "static-analysis"],
  "license": "UNLICENSED",
  "private": true
}
