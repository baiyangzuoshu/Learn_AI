{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linkup.dev/schemas/scenario.schema.json",
  "title": "Agent Scenario",
  "description": "Defines a single agent evaluation scenario",
  "type": "object",
  "required": ["id", "title", "version", "enabled", "phase", "taskType", "prompt", "setup", "permissions", "assertions", "scoring", "timeoutSeconds", "tags"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^E[0-9]{3}$",
      "description": "Unique scenario identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "phase": {
      "type": "string",
      "enum": ["G5", "G6", "G4"]
    },
    "taskType": {
      "type": "string",
      "enum": ["read", "diagnose", "modify-fixture", "mcp", "runtime"]
    },
    "prompt": {
      "type": "string",
      "minLength": 1,
      "description": "The task prompt given to the agent"
    },
    "setup": {
      "$ref": "#/$defs/ScenarioSetup"
    },
    "permissions": {
      "$ref": "#/$defs/ScenarioPermissions"
    },
    "assertions": {
      "$ref": "#/$defs/ScenarioAssertions"
    },
    "scoring": {
      "$ref": "#/$defs/ScenarioScoring"
    },
    "timeoutSeconds": {
      "type": "integer",
      "minimum": 30,
      "maximum": 3600
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ScenarioSetup": {
      "type": "object",
      "required": ["workspaceMode", "requiredCapabilities", "preconditions"],
      "properties": {
        "sourceFixture": {
          "type": "string",
          "description": "Fixture directory name if using isolated-fixture mode"
        },
        "workspaceMode": {
          "type": "string",
          "enum": ["read-only-real", "temp-copy", "isolated-fixture"]
        },
        "requiredCapabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["files", "shell", "skill", "linkup-check", "mcp", "runtime"]
          },
          "uniqueItems": true
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "ScenarioPermissions": {
      "type": "object",
      "required": ["allowedReadPaths", "allowedWritePaths", "forbiddenPaths", "network", "externalMutation", "gitMutation"],
      "properties": {
        "allowedReadPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedWritePaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbiddenPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "network": {
          "type": "string",
          "enum": ["forbidden", "allowed-with-approval"]
        },
        "externalMutation": {
          "type": "string",
          "enum": ["forbidden", "allowed-with-approval"]
        },
        "gitMutation": {
          "type": "string",
          "enum": ["forbidden", "allowed-with-approval"]
        }
      },
      "additionalProperties": false
    },
    "ScenarioAssertions": {
      "type": "object",
      "required": ["mustObserve", "mustUse", "mustRunCommands", "mustProduceEvidence", "mustNotClaim", "mustNotUse"],
      "properties": {
        "mustObserve": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustUse": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustRunCommands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustProduceEvidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustNotClaim": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustNotUse": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expectedDiagnostics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ruleId"],
            "properties": {
              "ruleId": { "type": "string" },
              "filePattern": { "type": "string" },
              "severity": { "type": "string", "enum": ["error", "warning", "info"] }
            },
            "additionalProperties": false
          }
        },
        "expectedFileChanges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbiddenFileChanges": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ScenarioScoring": {
      "type": "object",
      "required": ["weights", "hardFailConditions", "passScore"],
      "properties": {
        "weights": {
          "type": "object",
          "required": ["safety", "correctness", "workflow", "evidence", "efficiency"],
          "properties": {
            "safety": { "type": "integer", "minimum": 0, "maximum": 100 },
            "correctness": { "type": "integer", "minimum": 0, "maximum": 100 },
            "workflow": { "type": "integer", "minimum": 0, "maximum": 100 },
            "evidence": { "type": "integer", "minimum": 0, "maximum": 100 },
            "efficiency": { "type": "integer", "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": false
        },
        "hardFailConditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "passScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    }
  }
}
