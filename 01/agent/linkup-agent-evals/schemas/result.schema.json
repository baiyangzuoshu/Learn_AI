{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linkup.dev/schemas/result.schema.json",
  "title": "Agent Run Result",
  "description": "Records the result of an agent evaluation run",
  "type": "object",
  "required": ["scenarioId", "runId", "startedAt", "finishedAt", "agentHost", "status", "observedFacts", "toolCalls", "commands", "fileChanges", "claims", "assertions", "scores", "hardFailures", "notes"],
  "properties": {
    "scenarioId": {
      "type": "string",
      "pattern": "^E[0-9]{3}$"
    },
    "runId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9-]+$"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "agentHost": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "model": { "type": "string" }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "blocked", "cancelled"]
    },
    "observedFacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvidenceItem" }
    },
    "toolCalls": {
      "type": "array",
      "items": { "$ref": "#/$defs/ToolCallRecord" }
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/CommandRecord" }
    },
    "fileChanges": {
      "type": "array",
      "items": { "$ref": "#/$defs/FileChangeRecord" }
    },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/ClaimRecord" }
    },
    "assertions": {
      "type": "array",
      "items": { "$ref": "#/$defs/AssertionResult" }
    },
    "scores": {
      "$ref": "#/$defs/Scores"
    },
    "hardFailures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "EvidenceItem": {
      "type": "object",
      "required": ["id", "kind", "source", "summary"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["file", "command", "diagnostic", "mcp-tool", "mcp-resource", "runtime", "screenshot", "diff"]
        },
        "source": { "type": "string" },
        "summary": { "type": "string" },
        "digest": { "type": "string" },
        "artifactPath": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ToolCallRecord": {
      "type": "object",
      "required": ["tool", "input", "output"],
      "properties": {
        "tool": { "type": "string" },
        "input": {},
        "output": {},
        "durationMs": { "type": "integer" },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CommandRecord": {
      "type": "object",
      "required": ["cwd", "command", "exitCode"],
      "properties": {
        "cwd": { "type": "string" },
        "command": { "type": "string" },
        "exitCode": { "type": "integer" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "durationMs": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "FileChangeRecord": {
      "type": "object",
      "required": ["path", "changeType"],
      "properties": {
        "path": { "type": "string" },
        "changeType": {
          "type": "string",
          "enum": ["created", "modified", "deleted"]
        },
        "oldHash": { "type": "string" },
        "newHash": { "type": "string" },
        "diff": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ClaimRecord": {
      "type": "object",
      "required": ["claim", "evidenceIds", "verified"],
      "properties": {
        "claim": { "type": "string" },
        "evidenceIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verified": { "type": "boolean" },
        "verificationMethod": { "type": "string" }
      },
      "additionalProperties": false
    },
    "AssertionResult": {
      "type": "object",
      "required": ["assertion", "status"],
      "properties": {
        "assertion": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "pending", "not-applicable"]
        },
        "evidence": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Scores": {
      "type": "object",
      "required": ["safety", "correctness", "workflow", "evidence", "efficiency", "total"],
      "properties": {
        "safety": { "type": "integer", "minimum": 0, "maximum": 100 },
        "correctness": { "type": "integer", "minimum": 0, "maximum": 100 },
        "workflow": { "type": "integer", "minimum": 0, "maximum": 100 },
        "evidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "efficiency": { "type": "integer", "minimum": 0, "maximum": 100 },
        "total": { "type": "integer", "minimum": 0, "maximum": 100 }
      },
      "additionalProperties": false
    }
  }
}
